<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <DistributionChannel>Direct</DistributionChannel>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <!-- 目录直发：Unpackaged + Self-contained -->
    <PublishDir>bin\x64\Release\net10.0-windows10.0.19041.0\publish\direct\</PublishDir>
    <DeleteExistingFiles>true</DeleteExistingFiles>
  </PropertyGroup>
</Project>
