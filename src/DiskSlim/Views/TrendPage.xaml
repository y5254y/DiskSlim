<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.TrendPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:vm="using:DiskSlim.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="900">

            <!-- 标题和时间范围选择 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="📈 空间增长趋势分析"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="时间范围：" VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ComboBox ItemsSource="{x:Bind ViewModel.TimeRanges}"
                              SelectedItem="{x:Bind ViewModel.SelectedTimeRange, Mode=TwoWay}"
                              Width="80"/>
                    <Button Command="{x:Bind ViewModel.LoadTrendDataCommand}"
                            Style="{StaticResource SubtleButtonStyle}">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 统计卡片 -->
            <Grid ColumnSpacing="12"
                  Visibility="{x:Bind ViewModel.HasData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="16,12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="最小已用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.MinValueText, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="16,12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="最大已用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.MaxValueText, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="16,12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="当前已用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.LatestValueText, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"
                                   Foreground="{ThemeResource SystemAccentColor}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="16,12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel>
                        <TextBlock Text="平均增长速率" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.GrowthRateText, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}" FontWeight="Bold"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 趋势图（折线图可视化）-->
            <Border CornerRadius="8" Padding="16,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="{x:Bind ViewModel.HasData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <TextBlock Text="空间使用趋势" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <!-- 自定义图表 Canvas，在 code-behind 中绘制 -->
                    <Canvas x:Name="TrendCanvas" Height="200" HorizontalAlignment="Stretch"/>
                    <!-- 时间轴标签 -->
                    <Grid>
                        <TextBlock x:Name="AxisStartLabel" Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AxisEndLabel" Text=""
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 数据点列表（辅助表格形式展示） -->
            <Border CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Visibility="{x:Bind ViewModel.HasData, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="快照数据记录" Padding="16,12,16,8"
                               Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <ListView
                        ItemsSource="{x:Bind ViewModel.TrendPoints, Mode=OneWay}"
                        SelectionMode="None"
                        MaxHeight="200">
                        <ListView.Header>
                            <Grid Padding="16,4" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="时间" FontWeight="SemiBold"
                                           Style="{StaticResource CaptionTextBlockStyle}"/>
                                <TextBlock Grid.Column="1" Text="已用空间" FontWeight="SemiBold"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="占比" FontWeight="SemiBold"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrendDataPoint">
                                <Grid Padding="4,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind TimeText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind TooltipText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind TooltipText}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- 增长预测 -->
            <Border CornerRadius="8" Padding="16,12"
                    Visibility="{x:Bind ViewModel.HasPrediction, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource SystemFillColorCautionBackground}"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE7BA;" FontSize="24"
                              Foreground="{ThemeResource SystemFillColorCautionBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.PredictionText, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 无数据占位 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                        Visibility="{x:Bind ViewModel.HasData, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE9D9;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="暂无趋势数据"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="请先在"历史快照"页面创建多个快照，之后趋势图将自动显示"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- 加载指示 -->
            <StackPanel HorizontalAlignment="Center" Spacing="12"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing Width="40" Height="40" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                <TextBlock Text="正在加载趋势数据..."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
