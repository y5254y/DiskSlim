<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:controls="using:DiskSlim.Controls"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="16">

            <!-- 顶部状态栏 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center"/>
                <Button
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 空间使用概览卡片 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 环形图控件 -->
                <controls:SpaceGaugeControl
                    Grid.Column="0"
                    Width="180"
                    Height="180"
                    UsagePercent="{x:Bind ViewModel.UsagePercent, Mode=OneWay}"
                    UsageText="{x:Bind ViewModel.UsagePercentText, Mode=OneWay}"/>

                <!-- 右侧统计信息 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12">
                    <!-- 已用 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="12" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="{ThemeResource SystemAccentColor}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="已使用" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.UsedSizeText, Mode=OneWay}"
                                   FontWeight="SemiBold"/>
                    </Grid>
                    <!-- 可用 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="12" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="可用" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.FreeSizeText, Mode=OneWay}"
                                   FontWeight="SemiBold"/>
                    </Grid>
                    <!-- 总容量 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="12" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="Transparent" Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                   StrokeThickness="1" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="总容量" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.TotalSizeText, Mode=OneWay}"
                                   FontWeight="SemiBold"/>
                    </Grid>

                    <ProgressBar
                        Value="{x:Bind ViewModel.UsagePercent, Mode=OneWay}"
                        Maximum="100"
                        Height="8"
                        CornerRadius="4"/>

                    <!-- 可释放空间提示 -->
                    <Border
                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                        CornerRadius="8"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            <TextBlock>
                                <Run Text="可释放约 "/>
                                <Run Text="{x:Bind ViewModel.EstimatedFreeableText, Mode=OneWay}"
                                     FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                <Run Text=" 空间"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 一键智能清理按钮 -->
            <Button
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Stretch"
                Height="48"
                Click="QuickClean_Click">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE74D;" FontSize="18"/>
                    <TextBlock Text="一键智能清理" FontSize="16"/>
                </StackPanel>
            </Button>

            <!-- 大文件排行榜 -->
            <TextBlock Text="最大文件/文件夹" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>

            <ListView
                ItemsSource="{x:Bind ViewModel.TopItems, Mode=OneWay}"
                SelectionMode="None"
                IsItemClickEnabled="False">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:FileItem">
                        <Grid Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                Glyph="{x:Bind IsDirectory, Converter={StaticResource BoolToFolderIconConverter}}"
                                FontSize="20"
                                Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind FullPath}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind SizeBytes, Converter={StaticResource FileSizeConverter}}"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>
</Page>
