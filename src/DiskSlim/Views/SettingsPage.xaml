<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="20,16" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MaxWidth="700">

            <!-- 标题 -->
            <StackPanel>
                <TextBlock Text="⚙️ 设置"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="配置定时扫描、通知阈值和其他选项"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 定时扫描设置 -->
            <Border CornerRadius="8" Padding="20,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE916;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="定时自动扫描" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="启用后将按设定计划自动扫描C盘并保存快照，让您随时了解磁盘空间变化趋势。"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <!-- 开关 -->
                    <ToggleSwitch
                        Header="启用定时扫描"
                        IsOn="{x:Bind ViewModel.IsScheduleEnabled, Mode=TwoWay}"
                        OnContent="已启用" OffContent="已关闭"/>

                    <!-- 配置项（启用时显示） -->
                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.IsScheduleEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="扫描频率：" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.ScheduleOptions}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSchedule, Mode=TwoWay}"
                                      HorizontalAlignment="Left" Width="150"/>
                        </Grid>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="执行时间：" VerticalAlignment="Center"/>
                            <NumberBox Grid.Column="1" Width="80"
                                       Header="时"
                                       Minimum="0" Maximum="23"
                                       Value="{x:Bind ViewModel.ScheduledHour, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Inline"/>
                            <TextBlock Grid.Column="2" Text="：" VerticalAlignment="Bottom" Margin="4,0,4,8"/>
                            <NumberBox Grid.Column="3" Width="80"
                                       Header="分"
                                       Minimum="0" Maximum="59"
                                       Value="{x:Bind ViewModel.ScheduledMinute, Mode=TwoWay}"
                                       SpinButtonPlacementMode="Inline"/>
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="下次运行：" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.NextRunTimeText, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemAccentColor}"/>
                        </Grid>
                    </StackPanel>

                    <!-- 保存按钮 -->
                    <Button Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SaveScheduleCommand}"
                            IsEnabled="{x:Bind ViewModel.IsScheduleLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ProgressRing Width="14" Height="14"
                                          IsActive="{x:Bind ViewModel.IsScheduleLoading, Mode=OneWay}"
                                          Visibility="{x:Bind ViewModel.IsScheduleLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <TextBlock Text="保存定时扫描设置"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 通知设置 -->
            <Border CornerRadius="8" Padding="20,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEA8F;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="空间不足通知" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="当C盘可用空间低于设定阈值时，将自动弹出 Windows 通知提醒您进行清理。"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <ToggleSwitch
                        Header="启用空间不足通知"
                        IsOn="{x:Bind ViewModel.IsNotificationEnabled, Mode=TwoWay}"
                        OnContent="已启用" OffContent="已关闭"/>

                    <StackPanel Spacing="8"
                                Visibility="{x:Bind ViewModel.IsNotificationEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="警告阈值：" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{x:Bind ViewModel.ThresholdOptions}"
                                      SelectedItem="{x:Bind ViewModel.SelectedThreshold, Mode=TwoWay}"
                                      HorizontalAlignment="Left" Width="120"/>
                        </Grid>
                    </StackPanel>

                    <!-- 测试通知按钮 -->
                    <Button Command="{x:Bind ViewModel.SendTestNotificationCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEA8F;" FontSize="14"/>
                            <TextBlock Text="发送测试通知"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border CornerRadius="8" Padding="20,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="关于 DiskSlim" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="DiskSlim - C盘瘦身大师" Style="{StaticResource BodyTextBlockStyle}"/>
                    <TextBlock Text="版本：Phase 3 Pro 版（.NET 10 + WinUI 3）"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="帮助您轻松管理和优化C盘空间，让电脑保持最佳状态。"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- 状态消息 -->
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemAccentColor}"
                       Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource NullToInvisibilityConverter}}"
                       TextWrapping="Wrap"/>

        </StackPanel>
    </ScrollViewer>
</Page>
