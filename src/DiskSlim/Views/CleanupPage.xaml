<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:helpers="using:DiskSlim.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Grid Grid.Row="0" Padding="24,16" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"/>
                <TextBlock Visibility="{x:Bind ViewModel.IsCleaning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Run Text="正在清理："/>
                    <Run Text="{x:Bind ViewModel.CurrentCleaningItem, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>

            <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectSafeItemsCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE73E;" FontSize="14"/>
                    <TextBlock Text="全选安全项"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Command="{x:Bind ViewModel.ScanCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE773;" FontSize="14"/>
                    <TextBlock Text="扫描空间"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.CleanCommand}"
                    IsEnabled="{x:Bind ViewModel.IsCleaning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    <TextBlock Text="开始清理"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 清理进度条 -->
        <ProgressBar
            Grid.Row="0"
            Value="{x:Bind ViewModel.CleanProgress, Mode=OneWay}"
            Maximum="100"
            Visibility="{x:Bind ViewModel.IsCleaning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
            VerticalAlignment="Bottom"
            Height="4"/>

        <!-- 清理项目列表 -->
        <ListView
            Grid.Row="1"
            Padding="24,8"
            ItemsSource="{x:Bind ViewModel.CleanupItems, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:CleanupItem">
                    <Grid Padding="0,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 勾选框 -->
                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center"/>

                        <!-- 图标 -->
                        <FontIcon Grid.Column="1" Glyph="{x:Bind IconGlyph}" FontSize="20"
                                  VerticalAlignment="Center"/>

                        <!-- 名称和描述 -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <Border
                                    Background="{x:Bind Safety, Converter={StaticResource SafetyLevelToBackgroundConverter}}"
                                    CornerRadius="4"
                                    Padding="6,2">
                                    <TextBlock
                                        Text="{x:Bind SafetyBadge}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <TextBlock
                                Text="{x:Bind Description}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- 预估大小 -->
                        <TextBlock Grid.Column="3" VerticalAlignment="Center" FontWeight="SemiBold"
                                   Text="{x:Bind EstimatedSize, Mode=OneWay, Converter={StaticResource FileSizeConverter}}"/>

                        <!-- 扫描中状态 -->
                        <ProgressRing Grid.Column="4" Width="20" Height="20"
                                      IsActive="{x:Bind IsScanning, Mode=OneWay}"
                                      Visibility="{x:Bind IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部汇总栏 -->
        <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="24,12" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24">
                <StackPanel>
                    <TextBlock Text="预计可释放" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalSelectedSizeText, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemAccentColor}"/>
                </StackPanel>
                <StackPanel Visibility="{x:Bind ViewModel.TotalCleanedSize, Mode=OneWay, Converter={StaticResource GreaterThanZeroToVisibilityConverter}}">
                    <TextBlock Text="已释放" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalCleanedSizeText, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
