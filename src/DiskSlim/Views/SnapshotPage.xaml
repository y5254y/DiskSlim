<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.SnapshotPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="历史快照" Style="{StaticResource SubtitleTextBlockStyle}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- 快照备注输入框 -->
            <TextBox Grid.Column="1" Width="200"
                     PlaceholderText="快照备注（可选）"
                     Text="{x:Bind ViewModel.NewSnapshotLabel, Mode=TwoWay}"
                     VerticalAlignment="Center"/>

            <!-- 新建快照按钮 -->
            <Button Grid.Column="2"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.CreateSnapshotCommand}"
                    IsEnabled="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ProgressRing Width="14" Height="14" IsActive="{x:Bind ViewModel.IsCreating, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <FontIcon Glyph="&#xEA35;" FontSize="14"
                              Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <TextBlock Text="新建快照"/>
                </StackPanel>
            </Button>

            <!-- 删除按钮 -->
            <Button Grid.Column="3"
                    Command="{x:Bind ViewModel.DeleteSnapshotCommand}"
                    Visibility="{x:Bind ViewModel.HasSnapshots, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                    <TextBlock Text="删除选中"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：快照列表 -->
            <Grid Grid.Column="0">
                <!-- 快照列表 -->
                <ListView
                    ItemsSource="{x:Bind ViewModel.Snapshots, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedSnapshot, Mode=TwoWay}"
                    SelectionMode="Single"
                    Visibility="{x:Bind ViewModel.HasSnapshots, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DiskSnapshot">
                            <Grid Padding="4,8" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xEA35;" FontSize="20"
                                          Foreground="{ThemeResource SystemAccentColor}"
                                          VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"
                                               Style="{StaticResource BodyTextBlockStyle}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind SnapshotTimeText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind UsedBytesText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 加载指示 -->
                <ProgressRing Width="32" Height="32"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 无数据占位 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            Visibility="{x:Bind ViewModel.HasSnapshots, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xEA35;" FontSize="36"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="暂无快照" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="点击"新建快照"保存当前状态"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 分隔线 -->
            <Border Grid.Column="0" Width="1" HorizontalAlignment="Right"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

            <!-- 右侧内容 -->
            <ScrollViewer Grid.Column="1" Padding="20,12" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">

                    <!-- 选中快照详情 -->
                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.SelectedSnapshot, Mode=OneWay, Converter={StaticResource NullToInvisibilityConverter}}">
                        <TextBlock Text="快照详情" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 总大小 -->
                            <Border Grid.Column="0" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel>
                                    <TextBlock Text="总大小" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedSnapshot.TotalBytesText, Mode=OneWay}"
                                               Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- 已用空间 -->
                            <Border Grid.Column="1" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel>
                                    <TextBlock Text="已用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedSnapshot.UsedBytesText, Mode=OneWay}"
                                               Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"
                                               Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- 可用空间 -->
                            <Border Grid.Column="2" Padding="16,12" CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel>
                                    <TextBlock Text="可用空间" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedSnapshot.FreeBytesText, Mode=OneWay}"
                                               Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 文件夹明细 -->
                        <TextBlock Text="文件夹明细（按大小排序）"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ListView
                            ItemsSource="{x:Bind ViewModel.SelectedSnapshot.FolderItems, Mode=OneWay}"
                            SelectionMode="None"
                            MaxHeight="200">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SnapshotFolderItem">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind FolderName}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind SizeBytesText}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- 分隔线 -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                            Visibility="{x:Bind ViewModel.HasSnapshots, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- 快照对比区域 -->
                    <StackPanel Spacing="12"
                                Visibility="{x:Bind ViewModel.HasSnapshots, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="📊 快照对比" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{x:Bind ViewModel.Snapshots, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.CompareSnapshot1, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="选择旧快照">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:DiskSnapshot">
                                        <TextBlock Text="{x:Bind DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Column="1" Text="→" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <ComboBox Grid.Column="2"
                                      ItemsSource="{x:Bind ViewModel.Snapshots, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.CompareSnapshot2, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="选择新快照">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:DiskSnapshot">
                                        <TextBlock Text="{x:Bind DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button Grid.Column="3"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.CompareSnapshotsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ProgressRing Width="14" Height="14"
                                                  IsActive="{x:Bind ViewModel.IsComparing, Mode=OneWay}"
                                                  Visibility="{x:Bind ViewModel.IsComparing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <TextBlock Text="开始对比"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- 对比摘要 -->
                        <TextBlock Text="{x:Bind ViewModel.DiffSummary, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Visibility="{x:Bind ViewModel.HasDiffResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- 对比结果列表 -->
                        <ListView
                            ItemsSource="{x:Bind ViewModel.DiffItems, Mode=OneWay}"
                            SelectionMode="None"
                            MaxHeight="300"
                            Visibility="{x:Bind ViewModel.HasDiffResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.Header>
                                <Grid Padding="12,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="文件夹" FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                    <TextBlock Grid.Column="1" Text="旧大小" FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="新大小" FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="变化量" FontWeight="SemiBold"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SnapshotDiffItem">
                                    <Grid Padding="0,4" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind FolderName}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind OldSizeText}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind NewSizeText}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind DeltaText}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <!-- 未选中时占位 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                                Visibility="{x:Bind ViewModel.SelectedSnapshot, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <FontIcon Glyph="&#xEA35;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="从左侧选择一个快照查看详情"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
