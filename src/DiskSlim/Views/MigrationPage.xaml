<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.MigrationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:services="using:DiskSlim.Services"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：可迁移文件夹列表 -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="选择要迁移的文件夹"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Padding="24,16"/>

            <ListView
                Grid.Row="1"
                Padding="24,0"
                ItemsSource="{x:Bind ViewModel.MigratableFolders, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedFolder, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="services:UserFolderInfo">
                        <Grid Padding="0,8" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" FontSize="24"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"/>
                                    <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                            CornerRadius="4" Padding="6,2"
                                            Visibility="{x:Bind IsMigrated, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="已迁移" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{x:Bind CurrentPath}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       Text="{x:Bind SizeBytes, Converter={StaticResource FileSizeConverter}}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 右侧：迁移配置面板 -->
        <Grid Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="迁移配置"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>

            <!-- 目标盘选择 -->
            <StackPanel Grid.Row="1" Spacing="4">
                <TextBlock Text="目标盘符" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox
                    HorizontalAlignment="Stretch"
                    SelectedValue="{x:Bind ViewModel.DestinationDrive, Mode=TwoWay}">
                    <ComboBoxItem Content="D:" Tag="D:"/>
                    <ComboBoxItem Content="E:" Tag="E:"/>
                    <ComboBoxItem Content="F:" Tag="F:"/>
                    <ComboBoxItem Content="G:" Tag="G:"/>
                </ComboBox>
            </StackPanel>

            <!-- 空间不足警告 -->
            <InfoBar Grid.Row="2"
                     IsOpen="{x:Bind ViewModel.HasSpaceError, Mode=OneWay}"
                     Severity="Error"
                     Title="空间不足"
                     Message="{x:Bind ViewModel.SpaceErrorMessage, Mode=OneWay}"
                     IsClosable="False"/>

            <!-- 进度显示 -->
            <StackPanel Grid.Row="3" Spacing="4"
                        Visibility="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"/>
                <ProgressBar Value="{x:Bind ViewModel.MigrationProgress, Mode=OneWay}" Maximum="100"/>
                <TextBlock Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="4" Spacing="8">
                <Button
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.MigrateCommand}"
                    IsEnabled="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                        <TextBlock Text="开始迁移"/>
                    </StackPanel>
                </Button>
                <Button HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CancelCommand}"
                        Visibility="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="取消"/>
                </Button>
            </StackPanel>

            <!-- 状态提示（非迁移中） -->
            <TextBlock Grid.Row="5"
                       Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.IsMigrating, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</Page>
