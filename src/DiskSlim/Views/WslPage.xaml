<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.WslPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Grid Grid.Row="0" Padding="24,16" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Style="{StaticResource BodyTextBlockStyle}"/>
            </StackPanel>

            <Button
                Grid.Column="1"
                Command="{x:Bind ViewModel.ScanCommand}"
                IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE773;" FontSize="14"/>
                    <TextBlock Text="扫描"/>
                </StackPanel>
            </Button>

            <Button
                Grid.Column="2"
                Command="{x:Bind ViewModel.ReclaimAllCommand}"
                Style="{StaticResource AccentButtonStyle}"
                IsEnabled="{x:Bind ViewModel.IsReclaiming, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE756;" FontSize="14"/>
                    <TextBlock Text="一键回收全部"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 主内容区域 -->
        <ScrollViewer Grid.Row="1" Padding="24,0,24,0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="0,0,0,16">

                <!-- 功能说明卡片 -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="WSL 虚拟磁盘压缩原理" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                            WSL 2 使用 .vhdx 虚拟磁盘文件存储 Linux 文件系统。该文件会随使用自动增大，但在删除文件后不会自动缩小。
                            本工具通过 diskpart 压缩 vhdx 文件，回收已删除文件占用的空间。
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                            <Run Text="⚠️ 注意：" FontWeight="SemiBold"/>
                            <Run Text="压缩过程中将关闭所有 WSL 实例，请保存 Linux 中正在进行的工作。"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- WSL 未安装提示 -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.IsWslNotInstalled, Mode=OneWay}"
                    IsClosable="False"
                    Severity="Informational"
                    Title="未检测到 WSL"
                    Message="此功能需要安装 Windows Subsystem for Linux（WSL 2）。请先在应用商店或命令行安装 WSL。"/>

                <!-- 管理员权限提示 -->
                <InfoBar
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Warning"
                    Title="需要管理员权限"
                    Message="压缩 vhdx 虚拟磁盘需要管理员权限（diskpart 要求）。如操作失败，请以管理员身份重启 DiskSlim。"/>

                <!-- 进度指示器（回收进行中） -->
                <ProgressBar
                    IsIndeterminate="True"
                    Visibility="{x:Bind ViewModel.IsReclaiming, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- 发行版列表 -->
                <ItemsControl
                    ItemsSource="{x:Bind ViewModel.Distributions, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasDistributions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:WslDistribution">
                            <Border
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20"
                                Margin="0,0,0,8">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Linux 图标 -->
                                    <FontIcon
                                        Grid.Column="0"
                                        Glyph="&#xE756;"
                                        FontSize="28"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>

                                    <!-- 发行版信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                Text="{x:Bind Name}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                            <Border
                                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE768;" FontSize="10" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                                    <TextBlock Text="运行中" FontSize="11" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Text="{x:Bind VhdxPath}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{x:Bind VhdxFound, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock
                                            Text="未找到 vhdx 文件"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            Visibility="{x:Bind VhdxFound, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        <TextBlock
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Visibility="{x:Bind VhdxFound, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Run Text="虚拟磁盘大小："/>
                                            <Run Text="{x:Bind VhdxSizeBytes, Converter={StaticResource FileSizeConverter}}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 回收按钮（DataTemplate 中无法直接绑定页面 ViewModel，通过 Tag 传递） -->
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Tag="{x:Bind}"
                                        Click="ReclaimButton_Click"
                                        IsEnabled="{x:Bind VhdxFound}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE896;" FontSize="14"/>
                                            <TextBlock Text="回收空间"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 输出日志区域 -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Visibility="{x:Bind ViewModel.HasOutputLog, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="操作日志" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                        </StackPanel>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                Text="{x:Bind ViewModel.OutputLog, Mode=OneWay}"
                                FontFamily="Consolas"
                                FontSize="12"
                                TextWrapping="Wrap"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部汇总栏 -->
        <Grid
            Grid.Row="2"
            Padding="24,12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.HasSaved, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <FontIcon Glyph="&#xE73E;" FontSize="16" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="本次共释放："/>
                    <Run Text="{x:Bind ViewModel.TotalSavedBytes, Mode=OneWay, Converter={StaticResource FileSizeConverter}}"
                         FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
