<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.SoftwareMovePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <Grid Grid.Row="0" Padding="24,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 统计信息 -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"/>
                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="C盘软件："/>
                    <Run Text="{x:Bind ViewModel.SystemDriveSoftwareCount, Mode=OneWay}"/>
                    <Run Text=" 个，合计 "/>
                    <Run Text="{x:Bind ViewModel.SystemDriveTotalSizeText, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
            </StackPanel>

            <!-- 仅显示C盘开关 -->
            <ToggleSwitch
                Grid.Column="1"
                Header="仅C盘软件"
                IsOn="{x:Bind ViewModel.ShowSystemDriveOnly, Mode=TwoWay}"
                VerticalAlignment="Center"/>

            <!-- 扫描按钮 -->
            <Button Grid.Column="2"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.ScanSoftwareCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE773;" FontSize="14"/>
                    <TextBlock Text="扫描软件"/>
                </StackPanel>
            </Button>

            <!-- 目标盘选择 -->
            <ComboBox Grid.Column="3" Header="目标盘符"
                      ItemsSource="{x:Bind ViewModel.AvailableDrives, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.TargetDrive, Mode=TwoWay}"/>
            <!--
            <ComboBox Grid.Column="3" Header="目标盘符"
                      SelectedValue="{x:Bind ViewModel.TargetDrive, Mode=TwoWay}">
                <ComboBoxItem Content="D:"/>
                <ComboBoxItem Content="E:"/>
                <ComboBoxItem Content="F:"/>
                <ComboBoxItem Content="G:"/>
            </ComboBox>
            -->

            <!-- 迁移按钮 -->
            <Button Grid.Column="4"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.MoveSoftwareCommand}"
                    IsEnabled="{x:Bind ViewModel.IsMoving, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                    <TextBlock Text="搬家"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 软件列表 -->
        <ListView
            Grid.Row="1"
            Padding="24,0"
            ItemsSource="{x:Bind ViewModel.SoftwareList, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedSoftware, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SoftwareInfo">
                    <Grid Padding="0,8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- 软件名称和发布者 -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <Border Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind MigratedToPath, Converter={StaticResource NullToInvisibilityConverter}}">
                                    <TextBlock Text="已搬家" Style="{StaticResource CaptionTextBlockStyle}" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Publisher}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <!-- 版本 -->
                        <TextBlock Grid.Column="1" Text="{x:Bind Version}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- 安装路径 -->
                        <TextBlock Grid.Column="2" Text="{x:Bind InstallLocation}"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>

                        <!-- 大小 -->
                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind InstallSizeBytes, Converter={StaticResource FileSizeConverter}}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部状态栏 -->
        <ProgressBar Grid.Row="2" Height="4"
                     IsIndeterminate="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                     Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</Page>
