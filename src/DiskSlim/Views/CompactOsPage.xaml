<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.CompactOsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="800">

            <!-- 状态卡片 -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 状态图标：压缩中显示绿色对勾，未压缩显示灰色信息图标 -->
                    <FontIcon
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="36"
                        Glyph="{x:Bind ViewModel.IsCompressed, Mode=OneWay, Converter={StaticResource BoolToSuccessIconConverter}}"
                        Foreground="{x:Bind ViewModel.IsCompressed, Mode=OneWay, Converter={StaticResource BoolToSuccessColorConverter}}" />

                    <!-- 状态文字 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                        <TextBlock
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                            Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EstimatedSavings, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind ViewModel.HasStatus, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- 加载指示器 -->
                    <ProgressRing
                        Grid.Column="2"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Width="32" Height="32" />
                </Grid>
            </Border>

            <!-- 功能介绍卡片 -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="什么是 CompactOS？" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        CompactOS 是 Windows 10/11 内置的系统文件压缩技术，使用 XPRESS 或 LZX 算法对系统文件进行透明压缩。
                        压缩后文件仍可正常读写，系统会自动在读写时解压/压缩，对性能影响极小。
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        <Run Text="💡 典型节省空间：" FontWeight="SemiBold"/>
                        <Run Text="1–3 GB（视已安装组件而定）"/>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}">
                        <Run Text="💻 适合机型：" FontWeight="SemiBold"/>
                        <Run Text="低存储容量设备（32/64 GB SSD），或 C 盘剩余空间极少的设备"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 管理员权限提示 -->
            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Warning"
                Title="需要管理员权限"
                Message="启用或禁用 CompactOS 压缩需要以管理员身份运行。如果操作失败，请右键点击 DiskSlim 以管理员身份运行。"/>

            <!-- 操作按钮区域 -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button
                    Command="{x:Bind ViewModel.LoadStatusCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="查询状态"/>
                    </StackPanel>
                </Button>

                <Button
                    Command="{x:Bind ViewModel.EnableCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    Visibility="{x:Bind ViewModel.IsCompressed, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7EA;" FontSize="14"/>
                        <TextBlock Text="启用压缩"/>
                    </StackPanel>
                </Button>

                <Button
                    Command="{x:Bind ViewModel.DisableCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                    Visibility="{x:Bind ViewModel.IsCompressed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE894;" FontSize="14"/>
                        <TextBlock Text="禁用压缩"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- 输出日志区域 -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Visibility="{x:Bind ViewModel.HasOutputLog, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9D5;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="操作日志" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    </StackPanel>
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            Text="{x:Bind ViewModel.OutputLog, Mode=OneWay}"
                            FontFamily="Consolas"
                            FontSize="12"
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
