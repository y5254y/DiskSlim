<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.CleanupReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：历史报告列表 -->
        <Grid Grid.Column="0" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题和刷新 -->
            <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="清理记录" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{x:Bind ViewModel.LoadReportsCommand}"
                        ToolTipService.ToolTip="刷新"
                        Style="{StaticResource SubtleButtonStyle}">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
            </Grid>

            <!-- 报告列表 -->
            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Reports, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedReport, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CleanupReport">
                        <Grid Padding="4,8" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <FontIcon Grid.Column="0" Glyph="&#xE74D;" FontSize="20"
                                      Foreground="{ThemeResource SystemAccentColor}"
                                      VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind CompletedAtText}" FontWeight="SemiBold"
                                           Style="{StaticResource BodyTextBlockStyle}"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="释放" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind TotalFreedText}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 加载指示 -->
            <ProgressRing Grid.Row="1" Width="32" Height="32"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- 无数据提示 -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                        Visibility="{x:Bind ViewModel.HasReports, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <FontIcon Glyph="&#xE74D;" FontSize="36"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Text="暂无清理记录"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="执行清理后记录会显示在这里"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 删除按钮 -->
            <Button Grid.Row="2" Margin="12,8"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.DeleteSelectedReportCommand}"
                    Visibility="{x:Bind ViewModel.HasReports, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                    <TextBlock Text="删除此记录"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 分隔线 -->
        <Border Grid.Column="0" Width="1" HorizontalAlignment="Right"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- 右侧：报告详情 -->
        <Grid Grid.Column="1" Padding="24,16"
              Visibility="{x:Bind ViewModel.SelectedReport, Mode=OneWay, Converter={StaticResource NullToInvisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 报告头部信息 -->
            <Grid Grid.Row="0" ColumnSpacing="24" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Bind ViewModel.SelectedReport.CompletedAtText, Mode=OneWay}"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel>
                            <TextBlock Text="总释放空间" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedReport.TotalFreedText, Mode=OneWay}"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="耗时" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.SelectedReport.DurationText, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 导出按钮 -->
                <Button Grid.Column="1" Command="{x:Bind ViewModel.ExportToTextCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A5;" FontSize="14"/>
                        <TextBlock Text="导出 TXT"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.ExportToHtmlCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7C3;" FontSize="14"/>
                        <TextBlock Text="导出 HTML"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Margin="0,0,0,12"/>

            <!-- 明细列表 -->
            <ListView
                Grid.Row="2"
                ItemsSource="{x:Bind ViewModel.SelectedReport.Items, Mode=OneWay}"
                SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="12,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="清理项目" FontWeight="SemiBold"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Grid.Column="1" Text="释放空间" FontWeight="SemiBold"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="状态" FontWeight="SemiBold"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CleanupReportItem">
                        <Grid Padding="0,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind Name}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                            <TextBlock Grid.Column="1" Text="{x:Bind FreedText}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>

                            <FontIcon Grid.Column="2" FontSize="14"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Glyph="{x:Bind Success, Converter={StaticResource BoolToSuccessIconConverter}}"
                                      Foreground="{x:Bind Success, Converter={StaticResource BoolToSuccessColorConverter}}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- 未选中时占位 -->
        <StackPanel Grid.Column="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                    Visibility="{x:Bind ViewModel.SelectedReport, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
            <FontIcon Glyph="&#xE9F9;" FontSize="48"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock Text="从左侧选择一条清理记录查看详情"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
