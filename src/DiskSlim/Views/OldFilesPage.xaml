<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DiskSlim.Views.OldFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DiskSlim.Views"
    xmlns:models="using:DiskSlim.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Grid Grid.Row="0" Padding="16,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 扫描类型 -->
            <TextBlock Grid.Column="0" Text="扫描类型：" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{x:Bind ViewModel.ScanTypeOptions}"
                      SelectedItem="{x:Bind ViewModel.SelectedScanType, Mode=TwoWay}"
                      Width="130"/>

            <!-- 未访问天数（仅旧文件时显示） -->
            <TextBlock Grid.Column="2" Text="未访问超过：" VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox Grid.Column="3"
                      ItemsSource="{x:Bind ViewModel.NotAccessedDaysOptions}"
                      SelectedItem="{x:Bind ViewModel.SelectedNotAccessedDays, Mode=TwoWay}"
                      Width="80"/>

            <!-- 状态信息 -->
            <TextBlock Grid.Column="4" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" Margin="12,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>

            <!-- 扫描按钮 -->
            <Button Grid.Column="5"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.ScanCommand}"
                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ProgressRing Width="14" Height="14"
                                  IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <FontIcon Glyph="&#xE721;" FontSize="14"
                              Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <TextBlock Text="开始扫描"/>
                </StackPanel>
            </Button>

            <!-- 取消按钮 -->
            <Button Grid.Column="6"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="取消"/>
            </Button>
        </Grid>

        <!-- 批量操作工具栏（有结果时显示） -->
        <Grid Grid.Row="1" Padding="16,4" ColumnSpacing="8"
              Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{x:Bind ViewModel.SelectAllCommand}">
                <TextBlock Text="全选"/>
            </Button>
            <Button Grid.Column="1" Command="{x:Bind ViewModel.SelectNoneCommand}">
                <TextBlock Text="取消全选"/>
            </Button>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" FontWeight="Bold"/>
                <TextBlock Text="个文件已选，合计"/>
                <TextBlock Text="{x:Bind ViewModel.TotalSelectedSizeText, Mode=OneWay}"
                           FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>
            </StackPanel>

            <Button Grid.Column="3"
                    Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                    IsEnabled="{x:Bind ViewModel.IsDeleting, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ProgressRing Width="14" Height="14"
                                  IsActive="{x:Bind ViewModel.IsDeleting, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsDeleting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <FontIcon Glyph="&#xE74D;" FontSize="14"
                              Visibility="{x:Bind ViewModel.IsDeleting, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <TextBlock Text="移到回收站"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 文件列表 -->
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.FileItems, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListView.Header>
                <Grid Padding="16,6" ColumnSpacing="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="选择" FontWeight="SemiBold" Width="36"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <TextBlock Grid.Column="1" Text="文件路径" FontWeight="SemiBold"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <TextBlock Grid.Column="2" Text="大小" FontWeight="SemiBold"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="最后访问" FontWeight="SemiBold"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="类型" FontWeight="SemiBold"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="操作" FontWeight="SemiBold" Width="50"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               HorizontalAlignment="Center"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:OldFileItem">
                    <Grid Padding="4,6" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" Width="36"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind FullPath}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{x:Bind SizeBytesText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>

                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{x:Bind LastAccessedText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind DaysSinceAccessText}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Column="4" Text="{x:Bind FileTypeName}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}"/>

                        <Button Grid.Column="5" Width="50" Padding="4"
                                Click="OpenInExplorerButton_Click"
                                Tag="{x:Bind FullPath}"
                                ToolTipService.ToolTip="在资源管理器中打开">
                            <FontIcon Glyph="&#xEC50;" FontSize="12"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 无结果占位 -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                    Visibility="{x:Bind ViewModel.HasResults, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <ProgressRing Width="40" Height="40"
                          IsActive="{x:Bind ViewModel.IsScanning, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <FontIcon Glyph="&#xE721;" FontSize="48"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 底部状态栏 -->
        <Grid Grid.Row="3" Padding="16,8"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
    </Grid>
</Page>
